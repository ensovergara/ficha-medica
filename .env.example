# ============================================================
# FICHA MÉDICA PET — Variables de entorno
# Copiar a .env y completar con valores reales
# ============================================================

# --- Entorno ------------------------------------------------
# "development" | "production"
ENVIRONMENT=development

# --- PostgreSQL ---------------------------------------------
POSTGRES_USER=vetadmin
POSTGRES_PASSWORD=vetpassword123          # CAMBIAR en producción
POSTGRES_DB=fichamedica
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vetadmin:vetpassword123@db:5432/fichamedica

# --- Backend ------------------------------------------------
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS: separar múltiples orígenes con coma
# Desarrollo:   http://localhost:3000
# Producción:   https://app.tudominio.com
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Frontend -----------------------------------------------
# Desarrollo:   http://localhost:8000/api/v1
# Producción:   https://api.tudominio.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# URL base del frontend (para magic links y portal público)
# Desarrollo:   http://localhost:3000
# Producción:   https://app.tudominio.com
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# --- Email (Resend) -----------------------------------------
# Sin API key los emails se imprimen en la consola del backend
# Obtener en: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dominio verificado en Resend (o usar onboarding@resend.dev para pruebas)
EMAIL_FROM=FichaMédica Pet <noreply@fichamedica.app>

# --- SuperAdmin (seed inicial) ------------------------------
# Solo se usa la primera vez que se levanta el sistema
SUPERADMIN_EMAIL=admin@fichamedica.com
SUPERADMIN_PASSWORD=admin123456           # CAMBIAR antes del primer deploy

# ============================================================
# NOTAS PARA PRODUCCIÓN
# ============================================================
# 1. SECRET_KEY: debe ser un string aleatorio de al menos 32 bytes
# 2. SUPERADMIN_PASSWORD: cambiar luego del primer login
# 3. POSTGRES_PASSWORD: usar una contraseña fuerte (>16 chars)
# 4. BACKEND_CORS_ORIGINS: solo el dominio real del frontend
# 5. NEXT_PUBLIC_API_URL: URL pública del backend (con HTTPS)
# 6. DATABASE_URL debe actualizarse si cambian user/password/host
# 7. FRONTEND_URL y NEXT_PUBLIC_FRONTEND_URL: URL pública del frontend
# 8. RESEND_API_KEY: sin este valor los emails van a consola (útil en dev)
# 9. EMAIL_FROM: debe ser un dominio verificado en Resend en producción
# ============================================================
